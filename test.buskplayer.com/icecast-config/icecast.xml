<?xml version="1.0"?>
<icecast>
    <!-- Basic Settings -->
    <location>Portland, Oregon</location>
    <admin>bencleek@yahoo.com</admin>
    
    <!-- Server Settings -->
    <limits>
        <clients>100</clients>
        <sources>2</sources>
        <queue-size>65536</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>0</burst-on-connect>
    </limits>
    
    <!-- Authentication -->
    <authentication>
        <source-password>EtherIsBetter</source-password>
        <relay-password>hackme</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>hackme</admin-password>
    </authentication>
    
    <!-- Hostname -->
    <hostname>test.buskplayer.com</hostname>
    
    <!-- Listen on all interfaces, port 8000 -->
    <listen-socket>
        <port>8000</port>
        <bind-address>0.0.0.0</bind-address>
    </listen-socket>
    
    <!-- Mount Points: none pre-defined; broadcaster controls mountpoint via SOURCE request.
         Uses default source-password (EtherIsBetter) for all mounts. -->
    
    <!-- Logging -->
    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>
    
    <!-- Security -->
    <security>
        <chroot>0</chroot>
    </security>
    
    <!-- File serving (for status pages) -->
    <fileserve>1</fileserve>
    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
        <alias source="/" dest="/status.xsl"/>
    </paths>
</icecast>
